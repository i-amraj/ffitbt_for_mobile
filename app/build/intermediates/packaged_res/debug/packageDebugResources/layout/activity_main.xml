<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════ HEADER ══════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">

                <!-- Logo + App name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@mipmap/ic_launcher"
                        android:background="@drawable/logo_bg"
                        android:padding="6dp"
                        android:contentDescription="FFit BT"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FFit BT"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bluetooth Print Driver"
                            android:textColor="#80FFFFFF"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Service pill badge -->
                    <TextView
                        android:id="@+id/tvServiceBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Service OFF"
                        android:textColor="#FFBF00"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Subtitle tagline -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Connect to your paired Bluetooth thermal printer and enable system-wide printing from any app."
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>

            <!-- ══════════════ BODY CARDS ══════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── Printer Connection Card ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Section label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRINTER STATUS"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="14dp"/>

                        <!-- Status row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <!-- Animated dot -->
                            <View
                                android:id="@+id/statusDot"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/dot_red"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No Printer Connected"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvMac"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    android:fontFamily="monospace"
                                    android:visibility="gone"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <!-- Scan Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnScan"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="🔍   SCAN PAIRED PRINTERS"
                            android:textColor="@color/dark_bg"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            app:backgroundTint="@color/cyan"
                            app:cornerRadius="12dp"
                            app:icon="@null"/>

                        <!-- Disconnect Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDisconnect"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="10dp"
                            android:text="DISCONNECT"
                            android:textColor="@color/red"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:backgroundTint="#1AEF4444"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/red"
                            app:strokeWidth="1dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── Test Print Card ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTestPrint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEST CONNECTION"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="14dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestPrint"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="🖨️   PRINT TEST PAGE"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            app:backgroundTint="@color/green"
                            app:cornerRadius="12dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── How To Use Card ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOW TO PRINT FROM ANY APP"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="14dp"/>

                        <!-- Step rows -->
                        <include layout="@layout/item_step"
                            android:id="@+id/step1"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step2"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step3"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step4"/>

                        <!-- Open Print Settings button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenPrintSettings"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="16dp"
                            android:text="⚙️   OPEN ANDROID PRINT SETTINGS"
                            android:textColor="@color/cyan"
                            android:textStyle="bold"
                            app:backgroundTint="#1A38BDF8"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/cyan"
                            app:strokeWidth="1dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="made by raj 🫶"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
