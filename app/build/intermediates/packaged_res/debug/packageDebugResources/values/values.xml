<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="amber">#F59E0B</color>
    <color name="card_bg">#1E293B</color>
    <color name="cyan">#38BDF8</color>
    <color name="dark_bg">#0F172A</color>
    <color name="divider">#334155</color>
    <color name="green">#22C55E</color>
    <color name="red">#EF4444</color>
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#94A3B8</color>
    <style name="AlertDialogDark" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorSurface">#1E293B</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="colorPrimary">#38BDF8</item>
    </style>
    <style name="BottomSheetModal" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="BottomSheetStyle" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetModal</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.FFitBT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan</item>
        <item name="colorPrimaryDark">@color/dark_bg</item>
        <item name="colorAccent">@color/cyan</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/card_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
    </style>
</resources>