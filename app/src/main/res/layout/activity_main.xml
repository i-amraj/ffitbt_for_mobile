<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════ HEADER ══════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <!-- Logo + App name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@mipmap/ic_launcher"
                        android:background="@drawable/logo_bg"
                        android:padding="6dp"
                        android:contentDescription="FFit BT"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FFit BT"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thermal Print Driver"
                            android:textColor="#80FFFFFF"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Service pill badge -->
                    <TextView
                        android:id="@+id/tvServiceBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Service OFF"
                        android:textColor="#FFBF00"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════ SERVICE DISABLED WARNING BANNER ══════════════ -->
            <LinearLayout
                android:id="@+id/layoutServiceWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1AEF4444"
                android:padding="16dp"
                android:layout_margin="16dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Print Service is Disabled"
                    android:textColor="@color/red"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="To print receipts from other apps like Chrome or Gmail, you must enable FFit BT in your system settings."
                    android:textColor="#E2E8F0"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:lineSpacingExtra="2dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnableServiceBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="ENABLE NOW"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/red"
                    app:cornerRadius="6dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"/>
            </LinearLayout>

            <!-- ══════════════ SHARED ACTIVE PRINTER STATUS ══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE PRINTER STATUS"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"/>

                    <!-- Status row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:id="@+id/statusDot"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/dot_red"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No Printer Configured"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvMac"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="monospace"
                                android:visibility="gone"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Disconnect Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisconnect"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="DISCONNECT / RESET"
                        android:textColor="@color/red"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:backgroundTint="#1AEF4444"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/red"
                        app:strokeWidth="1dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════ TAB NAVIGATION ══════════════ -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:tabGravity="fill"
                app:tabMode="fixed"
                app:tabTextColor="@color/text_secondary"
                app:tabSelectedTextColor="@color/cyan"
                app:tabIndicatorColor="@color/cyan"
                app:tabBackground="@color/card_bg"
                app:tabIndicatorHeight="3dp"/>

            <!-- ══════════════ BODY PANELS ══════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- ── BLUETOOTH PANEL ── -->
                <LinearLayout
                    android:id="@+id/layoutBluetooth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BLUETOOTH PAIRING"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"
                                android:layout_marginBottom="14dp"/>

                            <!-- Scan Button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnScan"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:text="🔍   SCAN PAIRED PRINTERS"
                                android:textColor="@color/dark_bg"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                app:backgroundTint="@color/cyan"
                                app:cornerRadius="12dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ── WIFI PANEL ── -->
                <LinearLayout
                    android:id="@+id/layoutWifi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="@color/card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WIFI PRINTER SETTINGS"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"
                                android:layout_marginBottom="16dp"/>

                            <!-- Wifi Name (SSID) -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColorHint="@color/text_secondary"
                                app:hintTextColor="@color/cyan"
                                app:boxStrokeColor="@color/cyan"
                                app:boxBackgroundColor="@color/card_bg"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWifiSsid"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="WiFi Name (SSID) - Optional"
                                    android:textColor="@color/text_primary"
                                    android:inputType="text"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- IP Address -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColorHint="@color/text_secondary"
                                app:hintTextColor="@color/cyan"
                                app:boxStrokeColor="@color/cyan"
                                app:boxBackgroundColor="@color/card_bg"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWifiIp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Printer IP Address"
                                    android:textColor="@color/text_primary"
                                    android:inputType="text"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Subnet Mask -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColorHint="@color/text_secondary"
                                app:hintTextColor="@color/cyan"
                                app:boxStrokeColor="@color/cyan"
                                app:boxBackgroundColor="@color/card_bg"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWifiSubnet"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Subnet Mask"
                                    android:textColor="@color/text_primary"
                                    android:inputType="text"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Port -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="18dp"
                                android:textColorHint="@color/text_secondary"
                                app:hintTextColor="@color/cyan"
                                app:boxStrokeColor="@color/cyan"
                                app:boxBackgroundColor="@color/card_bg"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWifiPort"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Port (Default: 9100)"
                                    android:textColor="@color/text_primary"
                                    android:inputType="number"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Save WiFi settings button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSaveWifi"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:text="💾   SAVE &amp; TEST WIFI"
                                android:textColor="@color/dark_bg"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                app:backgroundTint="@color/cyan"
                                app:cornerRadius="12dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ── TEST PRINT CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTestPrint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEST CONNECTION"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="14dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestPrint"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="🖨️   PRINT TEST PAGE"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            app:backgroundTint="@color/green"
                            app:cornerRadius="12dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── OEM BACKGROUND AUTOSTART TROUBLESHOOTING CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/layoutOEMTroubleshooting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIVO / OPPO / XIAOMI SYSTEM FIX"
                            android:textColor="@color/amber"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chinese ROMs block background apps. To prevent print jobs from failing, you must manually grant Autostart and Battery Exemption permissions."
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:layout_marginBottom="14dp"
                            android:lineSpacingExtra="2dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenOEMSettings"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="⚙️   OPEN AUTOSTART SETTINGS"
                            android:textColor="@color/amber"
                            android:textStyle="bold"
                            app:backgroundTint="#1AF59E0B"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/amber"
                            app:strokeWidth="1dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── HOW TO USE CARD ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOW TO PRINT FROM ANY APP"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="14dp"/>

                        <!-- Step rows -->
                        <include layout="@layout/item_step"
                            android:id="@+id/step1"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step2"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step3"/>

                        <View android:layout_width="match_parent" android:layout_height="10dp"/>

                        <include layout="@layout/item_step"
                            android:id="@+id/step4"/>

                        <!-- Open Print Settings button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenPrintSettings"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="16dp"
                            android:text="⚙️   OPEN SYSTEM PRINTING"
                            android:textColor="@color/cyan"
                            android:textStyle="bold"
                            app:backgroundTint="#1A38BDF8"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/cyan"
                            app:strokeWidth="1dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── PRINT QUEUE & LOGS CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardQueueLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="PRINT QUEUE &amp; LOG HISTORY"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"/>

                            <TextView
                                android:id="@+id/tvRefreshLogs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="REFRESH"
                                android:textColor="@color/cyan"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="4dp"
                                android:layout_marginEnd="14dp"/>

                            <TextView
                                android:id="@+id/tvClearLogs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CLEAR ALL"
                                android:textColor="#EF4444"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="4dp"/>
                        </LinearLayout>

                        <!-- Empty state -->
                        <TextView
                            android:id="@+id/tvQueueEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No recent print jobs."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"/>

                        <!-- List of Print Logs -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPrintLogs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:visibility="gone"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="made by raj 🫶"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
